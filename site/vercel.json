{
  "cleanUrls": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/conta", "destination": "/conta.html" },
    { "source": "/servicos", "destination": "/servicos.html" },
    { "source": "/equipe", "destination": "/equipe.html" },
    { "source": "/galeria", "destination": "/galeria.html" },
    { "source": "/agendar", "destination": "/agendar.html" },
    { "source": "/localizacao", "destination": "/localizacao.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog-corte-rosto", "destination": "/blog-corte-rosto.html" },
    { "source": "/blog-navalha", "destination": "/blog-navalha.html" },
    { "source": "/blog-degrade", "destination": "/blog-degrade.html" },
    { "source": "/blog-rotina-capilar", "destination": "/blog-rotina-capilar.html" },
    { "source": "/blog-tesoura-maquina", "destination": "/blog-tesoura-maquina.html" },
    { "source": "/blog-3-cortes", "destination": "/blog-3-cortes.html" },
    { "source": "/blog-barbearia-premium", "destination": "/blog-barbearia-premium.html" }
  ]
}